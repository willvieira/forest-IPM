# History files
.Rhistory
.Rapp.history

# Session Data files
.RData

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
/*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# Shiny token, see https://shiny.rstudio.com/articles/shinyapps.html
rsconnect/
data/parameters
simulations/old
simulations/*/output
*.pdf
*.png
_data.path

# ignore some simulations
simulations/lambda_plotv*
simulations/par.mPop_effect

# C++ compiled artifacts
src/*.o
src/*.so
src/*.dll

# Profiling and benchmark outputs
*.rds
*.html

# Exceptions: test fixtures must be tracked
#!tests/testthat/fixtures/*.rds
# Exceptions: profiling flamegraph artifacts in .planning must be tracked
!.planning/phases/*/profvis_output.html
!.planning/phases/*/profvis_multi_output.html